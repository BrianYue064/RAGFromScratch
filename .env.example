# RAG Pipeline — Environment Configuration
# Copy to .env and adjust values for your setup.
# All variables are optional — defaults are shown below.

# ── Ingestion / Chunking ────────────────────────────────────────────
RAG_CHUNK_SIZE=768              # Target token count per chunk
RAG_OVERLAP=150                 # Overlap tokens between chunks
RAG_ENCODING=cl100k_base        # tiktoken encoding name

# ── Embedding (Ollama) ──────────────────────────────────────────────
RAG_OLLAMA_URL=http://localhost:11434
RAG_EMBEDDING_MODEL=embeddinggemma:latest
RAG_EMBEDDING_DIM=768           # Must match the model's output dimension

# ── Vector Store (PostgreSQL + pgvector) ─────────────────────────────
RAG_DB_URL=postgresql://postgres@localhost:5432/rag

# ── LLM Generation ──────────────────────────────────────────────────
RAG_LLM_PROVIDER=lmstudio       # "ollama" or "lmstudio"
RAG_LLM_MODEL=qwen3.5-0.8b     # Model name recognized by the provider
RAG_LMSTUDIO_URL=http://localhost:1234
RAG_LLM_TEMPERATURE=0.7
RAG_LLM_MAX_TOKENS=1024

# ── Retrieval ────────────────────────────────────────────────────────
RAG_TOP_K=10                    # Number of chunks returned by similarity search

# ── API Server ───────────────────────────────────────────────────────
RAG_API_HOST=127.0.0.1
RAG_API_PORT=8000
